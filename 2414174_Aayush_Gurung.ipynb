      "source": [
        "lemmatizer  = WordNetLemmatizer()\n",
        "stop_words  = set(stopwords.words('english'))\n",
        "\n",
        "def clean_text(text: str) -> str:\n",
        "    \"\"\"Full NLP preprocessing pipeline for a single text string.\n",
        "\n",
        "    Steps are ordered deliberately:\n",
        "      1. Contraction expansion before any punctuation removal\n",
        "      2. URL/mention removal before general character strip (avoids leaving\n",
        "         junk tokens like 'http', 'com' in the vocabulary)\n",
        "      3. Lemmatisation after stopword removal (smaller token list = faster)\n",
        "\n",
        "    Lemmatisation note: WordNetLemmatizer defaults to noun POS. This is an\n",
        "    acceptable trade-off for book reviews (noun-heavy vocabulary) vs the added\n",
        "    complexity and runtime of full POS tagging per token.\n",
        "    \"\"\"\n",
        "    if not isinstance(text, str):\n",
        "        return \"\"\n",
        "\n",
        "    # 1. Expand contractions FIRST — must precede any punctuation removal\n",
        "    text = contractions.fix(text)\n",
        "\n",
        "    # 2. Lowercase\n",
        "    text = text.lower()\n",
        "\n",
        "    # 3. Remove URLs — targeted regex before general strip\n",
        "    #    (broad strip would leave 'http', 'com' as vocabulary noise)\n",
        "    text = re.sub(r'http\\S+|www\\.\\S+', '', text)\n",
        "\n",
        "    # 4. Remove @mentions and #hashtags — social media noise\n",
        "    text = re.sub(r'@\\w+|#\\w+', '', text)\n",
        "\n",
        "    # 5. Remove digits\n",
        "    text = re.sub(r'\\d+', '', text)\n",
        "\n",
        "    # 6. Remove all remaining non-alphabetic characters\n",
        "    #    (safe to do broadly now that URL/mention noise is already gone)\n",
        "    text = re.sub(r'[^a-z\\s]', '', text)\n",
        "\n",
        "    # 7. Collapse whitespace\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "\n",
        "    # 8. Stopword removal + lemmatisation (noun-default POS — see docstring)\n",
        "    tokens = [\n",
        "        lemmatizer.lemmatize(w)\n",
        "        for w in text.split()\n",
        "        if w not in stop_words and len(w) > 2\n",
        "    ]\n",
        "\n",
        "    return ' '.join(tokens)\n",
        "\n",
        "# Apply to dataset\n",
        "df['cleaned_text'] = df[text_col].apply(clean_text)\n",
        "\n",
        "# Remove rows where cleaning produced empty strings\n",
        "df = df[df['cleaned_text'].str.strip().str.len() > 0].reset_index(drop=True)\n",
        "\n",
        "print(f\"Dataset size after cleaning: {len(df)}\")\n",
        "print(\"\\n--- Sample Before/After ---\")\n",
        "for i in range(3):\n",
        "    print(f\"\\nOriginal : {str(df[text_col].iloc[i])[:120]}\")\n",
        "    print(f\"Cleaned  : {df['cleaned_text'].iloc[i][:120]}\")\n"
      ]
    },
