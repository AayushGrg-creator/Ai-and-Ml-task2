      "source": [
        "tf.random.set_seed(RANDOM_SEED)\n",
        "\n",
        "rnn_model = Sequential([\n",
        "    Embedding(input_dim=VOCAB_SIZE, output_dim=EMBED_DIM,\n",
        "              input_length=MAX_LEN, name='embedding_rnn'),\n",
        "    SimpleRNN(units=128, return_sequences=False, name='simple_rnn'),\n",
        "    Dropout(0.4, name='dropout_rnn'),\n",
        "    Dense(64, activation='relu', name='dense_rnn'),\n",
        "    Dropout(0.3),\n",
        "    Dense(OUTPUT_UNITS, activation=OUTPUT_ACTIVATION, name='output_rnn')\n",
        "], name='SimpleRNN_Model')\n",
        "\n",
        "rnn_model.compile(optimizer='adam',\n",
        "                   loss=LOSS_FUNCTION,\n",
        "                   metrics=['accuracy'])\n",
        "\n",
        "rnn_model.summary()"
      ]
    },
