        "ax.axvline(MAX_LEN, color='red', linestyle='--', linewidth=2,\n",
        "           label=f'95th pct = {MAX_LEN}')\n",
        "ax.set_xlabel('Sequence Length (tokens)')\n",
        "ax.set_ylabel('Count')\n",
        "ax.set_title('Distribution of Review Lengths (after tokenization)', fontweight='bold')\n",
        "ax.legend()\n",
        "plt.tight_layout()\n",
