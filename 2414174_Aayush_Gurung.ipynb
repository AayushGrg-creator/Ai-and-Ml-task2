      "source": [
        "# ── Identify TEXT and LABEL columns automatically ────────────────────────────\n",
        "# Common column name patterns\n",
        "TEXT_CANDIDATES  = ['review_text', 'reviewText', 'review', 'text', 'comment',\n",
        "                    'Review', 'Text', 'description']\n",
        "LABEL_CANDIDATES = ['sentiment', 'label', 'rating', 'score', 'Rating',\n",
        "                    'Sentiment', 'Label', 'overall']\n",
        "\n",
        "text_col  = next((c for c in TEXT_CANDIDATES  if c in df.columns), None)\n",
        "label_col = next((c for c in LABEL_CANDIDATES if c in df.columns), None)\n",
        "\n",
        "# Fallback: pick first string column & first numeric column\n",
        "if text_col is None:\n",
        "    text_col = df.select_dtypes(include='object').columns[0]\n",
        "if label_col is None:\n",
        "    label_col = df.select_dtypes(include=['int64','float64']).columns[0]\n",
