      "source": [
        "# ── Collect misclassified examples ───────────────────────────────────────────\n",
        "label_names = ['Negative', 'Positive'] if NUM_CLASSES == 2 else [f'Class {i}' for i in range(NUM_CLASSES)]\n",
        "\n",
        "misclassified_idx = np.where(pred_w2v != y_test)[0]\n",
        "print(f\"Total misclassified (Model 3): {len(misclassified_idx)}\"\n",
        "      f\" / {len(y_test)}  ({len(misclassified_idx)/len(y_test)*100:.1f}%)\")\n",
        "\n",
        "# ── Categorise errors ────────────────────────────────────────────────────────\n",
        "false_positives = [i for i in misclassified_idx if y_test[i] == 0 and pred_w2v[i] == 1]\n",
        "false_negatives = [i for i in misclassified_idx if y_test[i] == 1 and pred_w2v[i] == 0]\n",
        "print(f\"  False Positives (predicted Positive, actually Negative): {len(false_positives)}\")\n",
        "print(f\"  False Negatives (predicted Negative, actually Positive): {len(false_negatives)}\")\n",
        "\n",
        "print(\"\\n\" + \"═\"*70)\n",
        "print(\"  DETAILED ERROR ANALYSIS — 3 False Positives + 3 False Negatives\")\n",
        "print(\"═\"*70)\n",
        "\n",
        "def explain_error(idx, example_num, error_type):\n",
        "    review   = X_test[idx]\n",
        "    true_lbl = label_names[y_test[idx]]\n",
        "    pred_lbl = label_names[pred_w2v[idx]]\n",
        "    words    = review.split()\n",
        "    length   = len(words)\n",
        "\n",
        "    # Heuristic diagnosis\n",
        "    sarcasm_signals  = ['great', 'fantastic', 'masterpiece', 'wonderful', 'amazing',\n",
        "                        'genius', 'brilliant', 'perfect', 'outstanding']\n",
        "    negation_signals = [\"not\", \"never\", \"hardly\", \"barely\", \"despite\", \"although\",\n",
        "                        \"however\", \"but\", \"though\", \"unfortunately\"]\n",
        "    has_sarcasm  = any(w in words for w in sarcasm_signals)\n",
        "    has_negation = any(w in words for w in negation_signals)\n",
        "\n",
        "    if length < 15:\n",
        "        reason = (f\"SHORT REVIEW ({length} words) — Insufficient context for confident \"\n",
        "                  f\"classification. The model defaults toward the majority class when \"\n",
        "                  f\"semantic signal is weak.\")\n",
        "    elif has_sarcasm and error_type == 'FP':\n",
        "        reason = (f\"LIKELY SARCASM/IRONY — The review contains positive sentiment words \"\n",
        "                  f\"(e.g. {[w for w in words if w in sarcasm_signals][:2]}) but the true \"\n",
        "                  f\"label is Negative. The LSTM reads these as genuine positives because \"\n",
        "                  f\"it has no pragmatic understanding of sarcasm.\")\n",
        "    elif has_negation and error_type == 'FN':\n",
        "        reason = (f\"NEGATION / CONTRAST — The review contains contrast words \"\n",
        "                  f\"(e.g. {[w for w in words if w in negation_signals][:2]}) which flip \"\n",
        "                  f\"the sentiment of nearby positive words. The LSTM partially learns \"\n",
        "                  f\"negation but struggles when the structure is complex.\")\n",
        "    elif length > 150:\n",
        "        reason = (f\"LONG REVIEW ({length} words) — Mixed sentiment across sections. \"\n",
        "                  f\"The model may weight the final portion disproportionately, especially \"\n",
        "                  f\"if the review pivots tone midway.\")\n",
        "    else:\n",
        "        reason = (f\"AMBIGUOUS LANGUAGE — The review uses domain-specific terms or \"\n",
        "                  f\"nuanced phrasing that the model's vocabulary may not encode well.\")\n",
        "\n",
        "    print(f\"\\nExample {example_num} [{error_type}]\")\n",
        "    print(f\"  Review    : {review[:200]}{'...' if len(review)>200 else ''}\")\n",
        "    print(f\"  True label: {true_lbl}  |  Predicted: {pred_lbl}  |  Length: {length} words\")\n",
        "    print(f\"  Diagnosis : {reason}\")\n",
        "\n",
        "for n, idx in enumerate(false_positives[:3], 1):\n",
        "    explain_error(idx, n, 'FP')\n",
        "\n",
        "for n, idx in enumerate(false_negatives[:3], 1):\n",
        "    explain_error(idx, n+3, 'FN')\n"
      ]
    },
