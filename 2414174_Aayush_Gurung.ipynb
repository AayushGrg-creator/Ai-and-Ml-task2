      ],
      "source": [
        "# ── Load Google News Pre-trained Word2Vec (300-dim) ─────────────────────────\n",
        "# NOTE: This downloads ~1.6 GB on first run. Colab caches it automatically.\n",
        "print(\"Loading Google News Word2Vec vectors (this may take a few minutes)...\")\n",
        "w2v_model = gensim_api.load('word2vec-google-news-300')\n",
        "print(f\"✅ Loaded. Vocabulary size: {len(w2v_model)}\")\n",
        "\n",
        "# Update embedding dimension to match the pre-trained vectors\n",
        "W2V_EMBED_DIM = 300   # Google News vectors are 300-dimensional\n",
        "\n",
        "# ── Build embedding matrix ────────────────────────────────────────────────────\n",
        "word_index = tokenizer.word_index\n",
        "embedding_matrix = np.zeros((VOCAB_SIZE, W2V_EMBED_DIM))\n",
        "oov_count = 0\n",
        "\n",
        "for word, idx in word_index.items():\n",
        "    if idx >= VOCAB_SIZE:\n",
        "        continue\n",
        "    if word in w2v_model:\n",
        "        embedding_matrix[idx] = w2v_model[word]\n",
        "    else:\n",
        "        oov_count += 1\n",
        "\n",
        "coverage = (1 - oov_count / min(len(word_index), VOCAB_SIZE)) * 100\n",
        "print(f\"Embedding matrix shape : {embedding_matrix.shape}\")\n",
        "print(f\"Vocabulary coverage    : {coverage:.1f}%\")\n"
      ]
    },
