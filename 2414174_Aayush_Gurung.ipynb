      "source": [
        "# ── Convert ratings to binary sentiment (if label column is numeric) ─────────\n",
        "if df[label_col].dtype in ['int64', 'float64']:\n",
        "    # Ratings 4-5 → Positive (1), Ratings 1-2 → Negative (0), drop 3 (neutral)\n",
        "    rating_max = df[label_col].max()\n",
        "    threshold_pos = rating_max * 0.6   # top 40%\n",
        "    threshold_neg = rating_max * 0.4   # bottom 40%\n",
        "\n",
        "    df = df[df[label_col] != 3].copy()   # drop neutral if rating-based\n",
        "    df['sentiment'] = (df[label_col] >= threshold_pos).astype(int)\n",
        "    label_col = 'sentiment'\n",
        "    print(\"Converted ratings to binary sentiment:\")\n",
        "else:\n",
        "    # Ensure numeric labels 0/1\n",
        "    unique_labels = df[label_col].unique()\n",
        "    label_map = {v: i for i, v in enumerate(sorted(unique_labels))}\n",
        "    df['sentiment'] = df[label_col].map(label_map)\n",
        "    label_col = 'sentiment'\n",
        "    print(f\"Label mapping: {label_map}\")\n",
        "\n",
        "print(df[label_col].value_counts())\n",
        "NUM_CLASSES = df[label_col].nunique()\n",
        "print(f\"\\nNumber of classes: {NUM_CLASSES}\")"
      ]
